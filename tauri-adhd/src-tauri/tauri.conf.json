{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Horus",
  "version": "0.1.0",
  "identifier": "com.feilun.horus",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Horus",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "resources": {
      "../models": "models",
      "../scripts/eye_tracker_server.py": "scripts/eye_tracker_server.py",
      "../scripts/model_pth": "scripts/model_pth",
      "../../eyetrack package": "eyetrack package"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}